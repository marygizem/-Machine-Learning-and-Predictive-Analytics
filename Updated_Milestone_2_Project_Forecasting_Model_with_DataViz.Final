        "id": "RNUqR9he3Tej"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 2) LOAD AND INSPECT THE DATA\n",
        "# ============================================================\n",
        "\"\"\"\n",
